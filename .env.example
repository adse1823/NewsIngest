# NewsAPI - get free key at https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# AlphaVantage - get free key at https://www.alphavantage.co
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here

# Redpanda broker
REDPANDA_BROKERS=localhost:29092
SCHEMA_REGISTRY_URL=http://localhost:8081

# Spark
SPARK_MASTER=local[2]
CHECKPOINT_DIR=./data/checkpoints

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# AWS (optional - for SageMaker sprint)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SAGEMAKER_ROLE_ARN=

# Snowflake (optional - for warehouse sprint)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=FIN_PLATFORM
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
